<!DOCTYPE html> 
<html> 
<head> 
<title>Student Registration</title> 
</head> 
<body> 
<h1>Register for Classes</h1> 
<form action="/submit" method="POST"> 
<label>Name:</label> 
<input type="text" name="studentName" required> 
<br><br> 
<label>Email:</label> 
<input type="email" name="studentEmail" required> 
<br><br> 
<label>Program:</label> 
<input type="text" name="studentProgram" required> 
<br><br> 
<label>Contact Number:</label> 
<input type="text" name="studentContact" required> 
<br><br> 
<button type="submit">Submit</button> 
</form> 
<hr> 
<h2>Registered Students</h2> 
<table border="1"> 
<tr> 
<th>ID</th> 
<th>Name</th> 
<th>Email</th> 
<th>Program</th> 
<th>Contact Number</th> 
</tr> 
<% students.forEach(student => { %> 
<tr> 
<td><%= student.id %></td> 
<td><%= student.name %></td> 
<td><%= student.email %></td> 
<td><%= student.program %></td> 
<td><%= student.contact_number %></td> 
</tr> 
<% }) %> 
</table> 
</body> 
</html> 